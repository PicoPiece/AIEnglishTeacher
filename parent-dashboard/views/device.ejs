<%- include('partials/header', { pageTitle: (device.alias || device.mac_address) + ' - Sessions', username }) %>

<div class="mb-6">
  <a href="/dashboard" class="text-sm text-primary-500 hover:text-primary-700 transition">&larr; Back to Dashboard</a>
</div>

<div class="flex items-center gap-3 mb-6">
  <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/>
    </svg>
  </div>
  <div>
    <h1 class="text-xl font-bold text-gray-800"><%= device.alias || device.mac_address %></h1>
    <div class="text-sm text-gray-400"><%= device.mac_address %> &middot; <%= device.board || 'Unknown board' %></div>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-700 mb-3">Chat Sessions</h2>

<% if (sessions.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-6 text-center text-gray-400">
    No conversations found for this device.
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border divide-y">
    <% sessions.forEach(s => { %>
      <a href="/history/<%= encodeURIComponent(s.session_id) %>"
         class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
        <div>
          <div class="text-sm font-medium text-gray-700">
            <%= new Date(s.started_at).toLocaleDateString('en-GB', { weekday:'short', day:'2-digit', month:'short', year:'numeric' }) %>
          </div>
          <div class="text-xs text-gray-400">
            <%= new Date(s.started_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
            &ndash;
            <%= new Date(s.last_msg_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="bg-primary-100 text-primary-700 text-xs font-medium px-2 py-0.5 rounded-full"><%= s.message_count %> msgs</span>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
