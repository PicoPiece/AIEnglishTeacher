<%- include('partials/header', { pageTitle: (device.alias || device.mac_address) + ' - Sessions', username }) %>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-400">
  <a href="/dashboard" class="hover:text-primary-500 transition">Dashboard</a>
  <span>/</span>
  <span class="text-gray-600"><%= device.alias || device.mac_address %></span>
</div>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <div>
      <h1 class="text-xl font-bold text-gray-800"><%= device.alias || device.mac_address %></h1>
      <div class="text-sm text-gray-400"><%= device.mac_address %> &middot; <%= device.board || 'Unknown board' %></div>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/device/<%= encodeURIComponent(device.mac_address) %>/stats"
       class="inline-flex items-center gap-1.5 bg-blue-50 hover:bg-blue-100 text-blue-600 text-sm font-medium px-3 py-2 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      Thống kê
    </a>
    <a href="/device/<%= encodeURIComponent(device.mac_address) %>/settings"
       class="inline-flex items-center gap-1.5 bg-purple-50 hover:bg-purple-100 text-purple-600 text-sm font-medium px-3 py-2 rounded-lg transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      Cài đặt AI
    </a>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-700 mb-3">Lịch sử hội thoại</h2>

<% if (sessions.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-6 text-center text-gray-400">
    No conversations found for this device.
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border divide-y">
    <% sessions.forEach(s => { %>
      <a href="/history/<%= encodeURIComponent(s.session_id) %>"
         class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
        <div>
          <div class="text-sm font-medium text-gray-700">
            <%= new Date(s.started_at).toLocaleDateString('en-GB', { weekday:'short', day:'2-digit', month:'short', year:'numeric' }) %>
          </div>
          <div class="text-xs text-gray-400">
            <%= new Date(s.started_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
            &ndash;
            <%= new Date(s.last_msg_at).toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' }) %>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <span class="bg-primary-100 text-primary-700 text-xs font-medium px-2 py-0.5 rounded-full"><%= s.message_count %> msgs</span>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </div>
      </a>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
