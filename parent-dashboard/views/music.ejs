<%- include('partials/header', { pageTitle: 'Thư viện nhạc', username }) %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 bg-pink-100 text-pink-600 rounded-xl flex items-center justify-center">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
      </svg>
    </div>
    <div>
      <h1 class="text-xl font-bold text-gray-800">Thư viện nhạc</h1>
      <div class="text-sm text-gray-400"><%= songs.length %> bài</div>
    </div>
  </div>
</div>

<!-- Category filter -->
<div class="flex items-center gap-2 mb-4 flex-wrap">
  <a href="/music"
     class="px-3 py-1.5 rounded-full text-sm font-medium transition
            <%= !activeCategory ? 'bg-pink-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
    Tất cả
  </a>
  <% categories.forEach(function(c) { %>
    <a href="/music?category=<%= c.value %>"
       class="px-3 py-1.5 rounded-full text-sm font-medium transition
              <%= activeCategory === c.value ? 'bg-pink-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>">
      <%= c.label %>
    </a>
  <% }) %>
</div>

<!-- Upload form -->
<div class="bg-white rounded-xl shadow-sm border p-5 mb-6">
  <h2 class="text-sm font-semibold text-gray-700 mb-3">Upload nhạc mới</h2>
  <form action="/music/upload" method="POST" enctype="multipart/form-data" class="space-y-3">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div>
        <label class="block text-xs text-gray-500 mb-1">Tên bài (tùy chọn)</label>
        <input type="text" name="title" placeholder="Tự lấy từ tên file" class="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-300 focus:border-pink-400 outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Nghệ sĩ</label>
        <input type="text" name="artist" placeholder="(tùy chọn)" class="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-300 focus:border-pink-400 outline-none">
      </div>
      <div>
        <label class="block text-xs text-gray-500 mb-1">Thể loại</label>
        <select name="category" class="w-full border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-pink-300 focus:border-pink-400 outline-none">
          <% categories.forEach(function(c) { %>
            <option value="<%= c.value %>" <%= activeCategory === c.value ? 'selected' : '' %>><%= c.label %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div>
      <label class="block text-xs text-gray-500 mb-1">Chọn file (MP3, WAV, OGG, M4A - tối đa 50MB)</label>
      <input type="file" name="files" accept=".mp3,.wav,.ogg,.m4a" multiple required
             class="w-full text-sm file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-pink-50 file:text-pink-600 file:font-medium hover:file:bg-pink-100 file:cursor-pointer">
    </div>
    <button type="submit" class="bg-pink-500 hover:bg-pink-600 text-white font-medium px-5 py-2 rounded-lg transition text-sm">
      Upload
    </button>
  </form>
</div>

<!-- Song list -->
<% if (songs.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-8 text-center text-gray-400">
    Chưa có bài nhạc nào. Hãy upload bài đầu tiên!
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border divide-y">
    <% songs.forEach(function(s, idx) { %>
      <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition group" id="song-<%= s.id %>">
        <div class="w-8 text-center text-xs text-gray-400 font-mono"><%= idx + 1 %></div>
        <button onclick="togglePlay(<%= s.id %>)" class="w-9 h-9 flex-shrink-0 bg-pink-50 text-pink-500 rounded-full flex items-center justify-center hover:bg-pink-100 transition">
          <svg id="play-icon-<%= s.id %>" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-800 truncate"><%= s.title %></div>
          <div class="text-xs text-gray-400 truncate">
            <%= s.artist || 'Unknown' %>
            <span class="mx-1">&middot;</span>
            <span class="bg-gray-100 px-1.5 py-0.5 rounded text-[10px]"><%= s.category %></span>
            <% if (s.file_size) { %>
              <span class="mx-1">&middot;</span>
              <span><%= (s.file_size / 1024 / 1024).toFixed(1) %> MB</span>
            <% } %>
          </div>
        </div>
        <form action="/music/<%= s.id %>/delete" method="POST" class="opacity-0 group-hover:opacity-100 transition"
              onsubmit="return confirm('Xóa bài này?')">
          <button type="submit" class="text-red-400 hover:text-red-600 p-1" title="Xóa">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </button>
        </form>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Hidden audio player -->
<audio id="audioPlayer" style="display:none"></audio>

<script>
let currentPlaying = null;
const player = document.getElementById('audioPlayer');

function togglePlay(id) {
  if (currentPlaying === id) {
    if (player.paused) { player.play(); updateIcon(id, true); }
    else { player.pause(); updateIcon(id, false); }
    return;
  }
  if (currentPlaying) updateIcon(currentPlaying, false);
  currentPlaying = id;
  player.src = '/api/music/stream/' + id;
  player.play();
  updateIcon(id, true);
}

function updateIcon(id, playing) {
  const icon = document.getElementById('play-icon-' + id);
  if (!icon) return;
  icon.innerHTML = playing
    ? '<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>'
    : '<path d="M8 5v14l11-7z"/>';
}

player.addEventListener('ended', () => {
  if (currentPlaying) { updateIcon(currentPlaying, false); currentPlaying = null; }
});
</script>

<%- include('partials/footer') %>
