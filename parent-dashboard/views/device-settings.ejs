<%- include('partials/header', { pageTitle: 'Cài đặt - ' + (device.alias || device.mac_address), username }) %>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-400">
  <a href="/dashboard" class="hover:text-primary-500 transition">Dashboard</a>
  <span>/</span>
  <a href="/device/<%= encodeURIComponent(device.mac_address) %>" class="hover:text-primary-500 transition"><%= device.alias || device.mac_address %></a>
  <span>/</span>
  <span class="text-gray-600">Cài đặt AI</span>
</div>

<div class="flex items-center gap-3 mb-6">
  <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
    </svg>
  </div>
  <div>
    <h1 class="text-xl font-bold text-gray-800">Tùy chỉnh AI</h1>
    <div class="text-sm text-gray-400"><%= device.alias || device.mac_address %></div>
  </div>
</div>

<% if (success) { %>
  <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">
    <%= success %>
    <span class="block text-xs text-green-500 mt-1">Thay đổi sẽ có hiệu lực khi thiết bị kết nối lại.</span>
  </div>
<% } %>
<% if (error) { %>
  <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"><%= error %></div>
<% } %>

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <div class="flex border-b" id="tabBar">
    <button type="button" id="tabStructured"
            class="flex-1 px-4 py-3 text-sm font-medium text-center transition tab-active"
            onclick="switchTab('structured')">
      Cài đặt cơ bản
    </button>
    <button type="button" id="tabAdvanced"
            class="flex-1 px-4 py-3 text-sm font-medium text-center transition text-gray-400 hover:text-gray-600"
            onclick="switchTab('advanced')">
      Chỉnh sửa nâng cao
    </button>
  </div>

  <form method="POST" action="/device/<%= encodeURIComponent(device.mac_address) %>/settings" id="settingsForm">

    <!-- Structured tab -->
    <div id="panelStructured" class="p-5 space-y-4">
      <input type="hidden" name="mode" id="modeInput" value="structured">

      <div>
        <label for="childName" class="block text-sm font-medium text-gray-700 mb-1">Tên bé</label>
        <input type="text" name="childName" id="childName"
               value="<%= structured ? structured.childName || '' : '' %>"
               placeholder="VD: Minh"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition">
      </div>

      <div>
        <label for="age" class="block text-sm font-medium text-gray-700 mb-1">Tuổi</label>
        <input type="number" name="age" id="age" min="2" max="18"
               value="<%= structured ? structured.age || '' : '' %>"
               placeholder="VD: 6"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition">
      </div>

      <div>
        <label for="level" class="block text-sm font-medium text-gray-700 mb-1">Level tiếng Anh</label>
        <select name="level" id="level"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition bg-white">
          <option value="">-- Chọn level --</option>
          <option value="beginner" <%= structured && structured.level === 'beginner' ? 'selected' : '' %>>Beginner (Mới bắt đầu)</option>
          <option value="intermediate" <%= structured && structured.level === 'intermediate' ? 'selected' : '' %>>Intermediate (Trung bình)</option>
          <option value="advanced" <%= structured && structured.level === 'advanced' ? 'selected' : '' %>>Advanced (Nâng cao)</option>
        </select>
      </div>

      <div>
        <label for="topics" class="block text-sm font-medium text-gray-700 mb-1">Chủ đề yêu thích</label>
        <textarea name="topics" id="topics" rows="2"
                  placeholder="VD: dinosaurs, space, animals, cooking"
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition resize-none"><%= structured ? structured.topics || '' : '' %></textarea>
        <div class="text-xs text-gray-400 mt-1">Các chủ đề cách nhau bằng dấu phẩy</div>
      </div>

      <div>
        <label for="extraNotes" class="block text-sm font-medium text-gray-700 mb-1">Ghi chú thêm cho AI</label>
        <textarea name="extraNotes" id="extraNotes" rows="3"
                  placeholder="VD: Bé thích được khen. Hãy dùng nhiều ví dụ về động vật."
                  class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition resize-none"><%= structured ? structured.extraNotes || '' : '' %></textarea>
      </div>
    </div>

    <!-- Advanced tab -->
    <div id="panelAdvanced" class="p-5 hidden">
      <div class="mb-3">
        <div class="flex items-center gap-2 mb-1">
          <label for="rawPrompt" class="block text-sm font-medium text-gray-700">System Prompt</label>
          <span class="text-xs bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded">Nâng cao</span>
        </div>
        <div class="text-xs text-gray-400 mb-2">Đây là toàn bộ prompt gửi cho AI. Chỉnh sửa nếu bạn hiểu rõ prompt engineering.</div>
      </div>
      <textarea name="rawPrompt" id="rawPrompt" rows="14"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-primary-300 focus:border-primary-400 outline-none transition resize-y"><%= rawPrompt || '' %></textarea>
    </div>

    <div class="px-5 pb-5 flex items-center gap-3">
      <button type="submit"
              class="bg-primary-500 hover:bg-primary-600 text-white font-medium px-6 py-2.5 rounded-lg text-sm transition shadow-sm">
        Lưu thay đổi
      </button>
      <a href="/device/<%= encodeURIComponent(device.mac_address) %>"
         class="text-sm text-gray-400 hover:text-gray-600 transition">Hủy</a>
    </div>
  </form>
</div>

<script>
  var currentTab = 'structured';

  function switchTab(tab) {
    if (tab === currentTab) return;
    if (tab === 'advanced' && currentTab === 'structured') {
      if (!confirm('Chuyển sang chế độ nâng cao? Nếu bạn chỉnh sửa trực tiếp prompt, các thay đổi từ form cơ bản có thể bị mất.')) return;
    }
    currentTab = tab;
    document.getElementById('modeInput').value = tab;
    var isStructured = tab === 'structured';
    document.getElementById('panelStructured').classList.toggle('hidden', !isStructured);
    document.getElementById('panelAdvanced').classList.toggle('hidden', isStructured);
    document.getElementById('tabStructured').className = isStructured
      ? 'flex-1 px-4 py-3 text-sm font-medium text-center transition tab-active'
      : 'flex-1 px-4 py-3 text-sm font-medium text-center transition text-gray-400 hover:text-gray-600';
    document.getElementById('tabAdvanced').className = !isStructured
      ? 'flex-1 px-4 py-3 text-sm font-medium text-center transition tab-active'
      : 'flex-1 px-4 py-3 text-sm font-medium text-center transition text-gray-400 hover:text-gray-600';
  }
</script>

<%- include('partials/footer') %>
