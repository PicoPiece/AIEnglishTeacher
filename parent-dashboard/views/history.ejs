<%- include('partials/header', { pageTitle: 'Lịch sử trò chuyện', username: username }) %>

<div class="mb-4">
  <a href="/dashboard" class="text-sm text-primary-500 hover:text-primary-700 transition">&larr; Quay lại Dashboard</a>
</div>

<div class="mb-6">
  <h1 class="text-xl font-bold text-gray-800">Lịch sử trò chuyện</h1>
  <p class="text-sm text-gray-400">Thiết bị: <%= deviceName %></p>
</div>

<% if (messages.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-8 text-center text-gray-400">
    Không có tin nhắn nào trong phiên này.
  </div>
<% } else { %>
  <div class="space-y-3 pb-4">
    <% var currentDate = ''; %>
    <% messages.forEach(function(m) { %>
      <%
        var msgDate = new Date(m.created_at).toLocaleDateString('vi-VN', { day:'2-digit', month:'long', year:'numeric' });
        var msgTime = new Date(m.created_at).toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });
        var isUser = (m.chat_type === 1);
        var displayContent = m.content || '';
        try {
          var parsed = JSON.parse(displayContent);
          if (parsed && parsed.content) displayContent = parsed.content;
        } catch(e) {}
      %>
      <% if (msgDate !== currentDate) { %>
        <% currentDate = msgDate; %>
        <div class="text-center my-4">
          <span class="bg-gray-200 text-gray-500 text-xs px-3 py-1 rounded-full"><%= msgDate %></span>
        </div>
      <% } %>

      <div class="flex <%= isUser ? 'justify-end' : 'justify-start' %>">
        <div class="max-w-[80%] sm:max-w-[70%]">
          <div class="text-xs mb-1 <%= isUser ? 'text-right text-gray-400' : 'text-left text-primary-400' %>">
            <%= isUser ? 'Bé nói' : 'AI Teacher' %>
            <span class="text-gray-300 ml-1"><%= msgTime %></span>
          </div>
          <div class="<%= isUser
            ? 'bg-green-100 text-gray-800 rounded-2xl rounded-tr-md'
            : 'bg-primary-100 text-gray-800 rounded-2xl rounded-tl-md'
          %> px-4 py-2.5 text-sm leading-relaxed shadow-sm">
            <%= displayContent %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
