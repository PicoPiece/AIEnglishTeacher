<%- include('partials/header', { pageTitle: 'Dashboard', username: username }) %>

<h1 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h1>

<section class="mb-8">
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Thiết bị của bé</h2>
  <% if (devices.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border p-6 text-center text-gray-400">
      Chưa có thiết bị nào được liên kết.
    </div>
  <% } else { %>
    <div class="grid gap-4 sm:grid-cols-2">
      <% devices.forEach(function(d) { %>
        <div class="bg-white rounded-xl shadow-sm border hover:shadow-md transition p-4">
          <%
            var now = Date.now();
            var last = d.last_connected_at ? new Date(d.last_connected_at).getTime() : 0;
            var diffMin = last ? Math.floor((now - last) / 60000) : 99999;
            var isOnline = diffMin < 5;
            var timeAgo = '';
            if (!last) timeAgo = 'Chưa kết nối';
            else if (diffMin < 5) timeAgo = 'Đang hoạt động';
            else if (diffMin < 60) timeAgo = diffMin + ' phút trước';
            else if (diffMin < 1440) timeAgo = Math.floor(diffMin/60) + ' giờ trước';
            else timeAgo = Math.floor(diffMin/1440) + ' ngày trước';
          %>
          <a href="/device/<%= encodeURIComponent(d.mac_address) %>" class="block">
            <div class="flex items-center gap-3 mb-3">
              <div class="relative">
                <div class="w-10 h-10 <%= isOnline ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-400' %> rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
                  </svg>
                </div>
                <span class="absolute -top-0.5 -right-0.5 w-3 h-3 rounded-full border-2 border-white <%= isOnline ? 'bg-green-500' : 'bg-gray-300' %>"></span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-semibold text-gray-800 truncate"><%= d.alias || d.mac_address %></div>
                <div class="text-xs text-gray-400"><%= d.agent_name || d.board || 'AI English Teacher' %></div>
              </div>
            </div>
          </a>
          <div class="flex items-center justify-between text-xs text-gray-500">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="inline-flex items-center gap-1 <%= isOnline ? 'text-green-600' : 'text-gray-400' %>">
                <span class="w-1.5 h-1.5 rounded-full <%= isOnline ? 'bg-green-500' : 'bg-gray-300' %>"></span>
                <%= timeAgo %>
              </span>
              <% if (d.app_version) { %>
                <span class="bg-gray-100 text-gray-500 px-1.5 py-0.5 rounded text-[10px]">v<%= d.app_version %></span>
              <% } %>
            </div>
            <div class="flex items-center gap-2">
              <a href="/device/<%= encodeURIComponent(d.mac_address) %>/stats"
                 class="text-gray-400 hover:text-blue-500 transition" title="Thống kê">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </a>
              <a href="/device/<%= encodeURIComponent(d.mac_address) %>/settings"
                 class="text-gray-400 hover:text-purple-500 transition" title="Cài đặt AI">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section>
  <h2 class="text-lg font-semibold text-gray-700 mb-3">Lịch sử hội thoại</h2>
  <% if (recentSessions.length === 0) { %>
    <div class="bg-white rounded-xl shadow-sm border p-6 text-center text-gray-400">
      Chưa có cuộc hội thoại nào. Hãy để bé bắt đầu nói chuyện!
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow-sm border divide-y">
      <% recentSessions.forEach(function(s) { %>
        <%
          var sDate = new Date(s.started_at);
          var now = Date.now();
          var diffMin = Math.floor((now - sDate.getTime()) / 60000);
          var timeLabel = '';
          if (diffMin < 5) timeLabel = 'Vừa xong';
          else if (diffMin < 60) timeLabel = diffMin + ' phút trước';
          else if (diffMin < 1440) timeLabel = Math.floor(diffMin/60) + ' giờ trước';
          else timeLabel = sDate.toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric' });

          var preview = s.first_student_msg || '';
          try {
            var parsed = JSON.parse(preview);
            if (parsed && parsed.content) preview = parsed.content;
          } catch(e) {}
          if (preview.length > 60) preview = preview.substring(0, 60) + '...';

          var startEnd = sDate.toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });
          var endTime = new Date(s.last_msg_at).toLocaleTimeString('vi-VN', { hour:'2-digit', minute:'2-digit' });

          var durationMin = Math.max(1, Math.floor((new Date(s.last_msg_at).getTime() - sDate.getTime()) / 60000));
        %>
        <a href="/history/<%= encodeURIComponent(s.session_id) %>"
           class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 transition">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-0.5">
              <span class="text-sm font-medium text-gray-800">
                <%= macToAlias[s.mac_address] || 'Thiết bị' %>
              </span>
              <span class="text-xs text-gray-400"><%= timeLabel %></span>
            </div>
            <% if (preview) { %>
              <div class="text-sm text-gray-500 truncate">"<%= preview %>"</div>
            <% } else { %>
              <div class="text-sm text-gray-400 italic">Cuộc hội thoại</div>
            <% } %>
            <div class="text-xs text-gray-400 mt-0.5">
              <%= startEnd %> – <%= endTime %> · <%= durationMin %> phút
            </div>
          </div>
          <div class="flex items-center gap-2 ml-3 flex-shrink-0">
            <span class="bg-primary-100 text-primary-700 text-xs font-medium px-2 py-0.5 rounded-full">
              <%= s.message_count %> tin nhắn
            </span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
