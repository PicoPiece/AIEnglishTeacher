<%- include('partials/header', { pageTitle: playlist.name + ' - Playlist', username }) %>

<div class="mb-4 flex items-center gap-2 text-sm text-gray-400">
  <a href="/playlists" class="hover:text-indigo-500 transition">Playlists</a>
  <span>/</span>
  <span class="text-gray-600"><%= playlist.name %></span>
</div>

<div class="flex items-center gap-3 mb-6">
  <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
    </svg>
  </div>
  <div>
    <h1 class="text-xl font-bold text-gray-800"><%= playlist.name %></h1>
    <div class="text-sm text-gray-400"><%= items.length %> bài<% if (playlist.description) { %> &middot; <%= playlist.description %><% } %></div>
  </div>
</div>

<!-- Songs in playlist -->
<% if (items.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-6 text-center text-gray-400 mb-6">
    Playlist chưa có bài nhạc nào.
  </div>
<% } else { %>
  <div class="bg-white rounded-xl shadow-sm border divide-y mb-6">
    <% items.forEach(function(s, idx) { %>
      <div class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition group">
        <div class="w-6 text-center text-xs text-gray-400 font-mono"><%= idx + 1 %></div>
        <button onclick="togglePlay(<%= s.id %>)" class="w-8 h-8 flex-shrink-0 bg-indigo-50 text-indigo-500 rounded-full flex items-center justify-center hover:bg-indigo-100 transition">
          <svg id="play-icon-<%= s.id %>" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </button>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-800 truncate"><%= s.title %></div>
          <div class="text-xs text-gray-400"><%= s.artist || 'Unknown' %> &middot; <span class="bg-gray-100 px-1.5 py-0.5 rounded text-[10px]"><%= s.category %></span></div>
        </div>
        <form action="/playlists/<%= playlist.id %>/remove-song" method="POST" class="opacity-0 group-hover:opacity-100 transition">
          <input type="hidden" name="item_id" value="<%= s.item_id %>">
          <button type="submit" class="text-red-400 hover:text-red-600 p-1 text-xs">Xóa</button>
        </form>
      </div>
    <% }) %>
  </div>
<% } %>

<!-- Add song to playlist -->
<% if (availableSongs.length > 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-5">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">Thêm bài nhạc</h2>
    <form action="/playlists/<%= playlist.id %>/add-song" method="POST" class="flex gap-3">
      <select name="music_id" required class="flex-1 border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none">
        <% availableSongs.forEach(function(s) { %>
          <option value="<%= s.id %>"><%= s.title %> - <%= s.artist || s.category %></option>
        <% }) %>
      </select>
      <button type="submit" class="bg-indigo-500 hover:bg-indigo-600 text-white font-medium px-5 py-2 rounded-lg transition text-sm whitespace-nowrap">
        Thêm
      </button>
    </form>
  </div>
<% } else { %>
  <div class="text-center text-sm text-gray-400">
    <a href="/music" class="text-indigo-500 hover:text-indigo-700 transition">Upload thêm nhạc</a> để thêm vào playlist.
  </div>
<% } %>

<!-- Hidden audio player -->
<audio id="audioPlayer" style="display:none"></audio>

<script>
let currentPlaying = null;
const player = document.getElementById('audioPlayer');

function togglePlay(id) {
  if (currentPlaying === id) {
    if (player.paused) { player.play(); updateIcon(id, true); }
    else { player.pause(); updateIcon(id, false); }
    return;
  }
  if (currentPlaying) updateIcon(currentPlaying, false);
  currentPlaying = id;
  player.src = '/api/music/stream/' + id;
  player.play();
  updateIcon(id, true);
}

function updateIcon(id, playing) {
  const icon = document.getElementById('play-icon-' + id);
  if (!icon) return;
  icon.innerHTML = playing
    ? '<rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/>'
    : '<path d="M8 5v14l11-7z"/>';
}

player.addEventListener('ended', () => {
  if (currentPlaying) { updateIcon(currentPlaying, false); currentPlaying = null; }
});
</script>

<%- include('partials/footer') %>
