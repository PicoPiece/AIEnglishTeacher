<%- include('partials/header', { pageTitle: 'Playlists', username }) %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <div class="w-12 h-12 bg-indigo-100 text-indigo-600 rounded-xl flex items-center justify-center">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
      </svg>
    </div>
    <div>
      <h1 class="text-xl font-bold text-gray-800">Playlists</h1>
      <div class="text-sm text-gray-400"><%= playlists.length %> playlist</div>
    </div>
  </div>
</div>

<!-- Create new playlist -->
<div class="bg-white rounded-xl shadow-sm border p-5 mb-6">
  <h2 class="text-sm font-semibold text-gray-700 mb-3">Tạo playlist mới</h2>
  <form action="/playlists" method="POST" class="flex gap-3">
    <input type="text" name="name" placeholder="Tên playlist" required
           class="flex-1 border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none">
    <input type="text" name="description" placeholder="Mô tả (tùy chọn)"
           class="flex-1 border rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none hidden sm:block">
    <button type="submit" class="bg-indigo-500 hover:bg-indigo-600 text-white font-medium px-5 py-2 rounded-lg transition text-sm whitespace-nowrap">
      Tạo
    </button>
  </form>
</div>

<!-- Playlist list -->
<% if (playlists.length === 0) { %>
  <div class="bg-white rounded-xl shadow-sm border p-8 text-center text-gray-400">
    Chưa có playlist nào. Tạo playlist đầu tiên ở trên!
  </div>
<% } else { %>
  <div class="grid gap-4 sm:grid-cols-2">
    <% playlists.forEach(function(p) { %>
      <div class="bg-white rounded-xl shadow-sm border hover:shadow-md transition p-4">
        <a href="/playlists/<%= p.id %>" class="block">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-10 h-10 bg-indigo-50 text-indigo-500 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="font-semibold text-gray-800 truncate"><%= p.name %></div>
              <div class="text-xs text-gray-400"><%= p.song_count %> bài &middot; <%= new Date(p.created_at).toLocaleDateString('vi-VN') %></div>
            </div>
          </div>
          <% if (p.description) { %>
            <div class="text-xs text-gray-400 truncate"><%= p.description %></div>
          <% } %>
        </a>
        <div class="flex items-center justify-end mt-2 gap-2">
          <a href="/playlists/<%= p.id %>" class="text-xs text-indigo-500 hover:text-indigo-700 transition">Chi tiết</a>
          <form action="/playlists/<%= p.id %>/delete" method="POST" class="inline"
                onsubmit="return confirm('Xóa playlist này?')">
            <button type="submit" class="text-xs text-red-400 hover:text-red-600 transition">Xóa</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('partials/footer') %>
